{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(date:*)",
      "Bash(du:*)",
      "Bash(echo:*)",
      "Bash(find*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(git:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(node .claude/*)",
      "Bash(npm run:*)",
      "Bash(npx skills:*)",
      "Bash(python3:*)",
      "Bash(docker-compose exec:*)",
      "Bash(docker-compose logs:*)",
      "Bash(code --wait *)",
      "Bash(obsidian:*)",
      "Bash(~/.claude/CLAUDE.md:*)",
      "WebFetch(*)",
      "WebSearch",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(git push:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true
  },
  "extraKnownMarketplaces": {
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    }
  },
  "language": "繁體中文",
  "spinnerTipsEnabled": false,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
